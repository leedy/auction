# MongoDB connection
MONGODB_URI=mongodb://user:password@host:27017/auction?authSource=admin

# LLM Configuration — OpenRouter (cloud) or Ollama (local)
# OpenRouter: https://openrouter.ai/keys
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-key
LLM_MODEL=openai/gpt-4o-mini

# Ollama (local):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=unused
# LLM_MODEL=qwen2.5:32b

# Optional: comma-separated models for test-llm-compare.mjs
# COMPARE_MODELS=openai/gpt-4o-mini,anthropic/claude-haiku-4-5-20251001

# Optional: extend SSRF allowlist for self-hosted LLM endpoints (comma-separated hostnames or .suffix).
# LLM_BASEURL_ALLOWLIST=openrouter.ai,api.openai.com,api.anthropic.com,my-internal-llm.example.com

# --- Auth (SECURITY-PLAN.md) ---
# Required when NODE_ENV=production. Server refuses to boot in prod without it.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Cookie flags. Set to true once served over HTTPS (production).
COOKIE_SECURE=false

# Trust X-Forwarded-For from N hops in front (1 = nginx). 0 = direct.
# Affects how req.ip is derived for rate limiting.
TRUST_PROXY=0

# Public origin (used in nginx config + future Docker env)
# PUBLIC_ORIGIN=https://auction.notesin9.com

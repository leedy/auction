# MongoDB connection
MONGODB_URI=mongodb://user:password@host:27017/auction?authSource=admin

# LLM Configuration — OpenRouter (cloud) or Ollama (local)
# OpenRouter: https://openrouter.ai/keys
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-key
LLM_MODEL=openai/gpt-4o-mini

# Ollama (local):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=unused
# LLM_MODEL=qwen2.5:32b

# Optional: comma-separated models for test-llm-compare.mjs
# COMPARE_MODELS=openai/gpt-4o-mini,anthropic/claude-haiku-4-5-20251001
